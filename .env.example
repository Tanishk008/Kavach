# ── Shared root environment (copy to .env) ─────────────────────────────
# Used by docker-compose to wire all services together.

# PostgreSQL
POSTGRES_USER=kavach
POSTGRES_PASSWORD=kavach_dev_password
POSTGRES_DB=kavach
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=kavach_dev_password
NEO4J_URI=bolt://neo4j:7687

# Backend
BACKEND_PORT=8000
# LLM provider for the classifier core (leave blank to use the deterministic mock)
LLM_API_KEY=
LLM_MODEL=claude-sonnet-5

# Real OTP SMS delivery
# Choose one provider: msg91 or twilio
SMS_PROVIDER=
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_OTP_EXPIRY_MINUTES=5
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Frontend
VITE_API_BASE_URL=http://localhost:8000
