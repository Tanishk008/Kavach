# Backend environment (copy to .env for local dev)

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=kavach
POSTGRES_PASSWORD=kavach_dev_password
POSTGRES_DB=kavach

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=kavach_dev_password

# Classifier LLM (leave LLM_API_KEY blank to use the deterministic mock classifier)
LLM_API_KEY=
LLM_MODEL=claude-sonnet-5

# CORS: comma-separated allowed origins for the frontend
CORS_ORIGINS=http://localhost:5173

# Real OTP SMS delivery
# Choose one provider: msg91 or twilio
SMS_PROVIDER=
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_OTP_EXPIRY_MINUTES=5
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
